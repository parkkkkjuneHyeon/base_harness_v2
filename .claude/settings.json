{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/description_gate.py" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/branch_guard.py" },
          { "type": "command", "command": "python3 .claude/hooks/approval_gate.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/post_write_check.py" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "code-generator|impact-analyzer|verifier",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/update_board.py" }
        ]
      }
    ]
  }
}
